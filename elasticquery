                "fields": [
                  "titular",
                  "texto"
                ]
              }
            }
          }
        },

        {
          "bool": {
            "filter": {
              "multi_match": {
                "query": "hospital del trabajador",
                "type": "phrase",
                "fields": [
                  "titular",
                  "texto"
                ]
              }
            }
          }
        }
